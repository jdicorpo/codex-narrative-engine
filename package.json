{
  "name": "codex-ide",
  "private": true,
  "workspaces": [
    "packages/codex-core",
    "packages/codex-obsidian"
  ],
  "scripts": {
    "prepare": "npm run build:core",
    "build": "npm run build:core && npm run build:obsidian",
    "build:core": "cd packages/codex-core && npm run build",
    "build:obsidian": "cd packages/codex-obsidian && npm run build",
    "test": "cd packages/codex-core && npm run test",
    "dev": "cd packages/codex-obsidian && npm run dev"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0"
  }
}
